{
    "name": "@xsecuro/core",
    "version": "1.0.0",
    "description": "Core library for xsecuro project",
    "keywords": [
        "password",
        "generator",
        "cryptography",
        "crypto"
    ],
    "homepage": "https://github.com/xsecuro/core",
    "bugs": {
        "url": "https://github.com/xsecuro/core/issues",
        "email": "xlebpushek@gmail.com"
    },
    "license": "MIT",
    "author": {
        "name": "Xlebp Rjanoi",
        "email": "xlebpushek@gmail.com",
        "url": "https://github.com/xsecuro"
    },
    "funding": {
        "type": "github",
        "url": "https://github.com/sponsors/xsecuro"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/xsecuro/core.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/types/index.mjs",
            "require": "./dist/types/index.cjs"
        },
        "./errors": {
            "types": "./dist/errors/index.d.ts",
            "import": "./dist/errors/index.mjs",
            "require": "./dist/errors/index.cjs"
        },
        "./generator": {
            "types": "./dist/generator/index.d.ts",
            "import": "./dist/generator/index.mjs",
            "require": "./dist/generator/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format:check": "prettier --check src/**/*.ts",
        "format:fix": "prettier --write src/**/*.ts",
        "specs": "jest",
        "specs:watch": "jest --watch",
        "specs:coverage": "jest --coverage",
        "docs": "typedoc src",
        "clean": "rimraf dist",
        "build": "unbuild",
        "prepublish": "npm run build"
    },
    "devDependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^11.0.3",
        "@semantic-release/npm": "^12.0.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.10",
        "conventional-changelog-conventionalcommits": "^9.1.0",
        "jest": "^30.0.4",
        "jest-mock-extended": "^4.0.0",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "semantic-release": "^24.2.7",
        "ts-jest": "^29.4.0",
        "typescript": "^5.8.3",
        "unbuild": "^3.5.0"
    },
    "trustedDependencies": [
        "unrs-resolver"
    ]
}
